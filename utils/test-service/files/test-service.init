#!/bin/sh /etc/rc.common
USE_PROCD=1
START=96
STOP=10
name="test-service"
PROG="/usr/bin/test-service.sh"
start_service() {
    procd_open_instance
    procd_set_param command "$PROG"
    procd_set_param respawn 300 5 3
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
